{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*",
    "./worker-configuration.d.ts"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": ["src/*"],
      "@core-webApp": ["src/core-webApp/index.ts"],
      "@core-webApp/*": ["src/core-webApp/*"],
      "@services": ["src/services/index.ts"],
      "@services/*": ["src/services/*"],
      "@site-package": ["src/site-package/index.ts"],
      "@site-package/*": ["src/site-package/*"],
      "@site": ["src/site-package/kellogg"],
      "@site/*": ["src/site-package/kellogg/*"],

    },
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  }
}
