---
import "../styles/global.css";
import { getSiteData } from "../lib/site";
import Header from "../components/Header";
import Footer from "../components/Footer.astro";
import TawkChat from "../components/TawkChat.astro";

interface Props {
	title?: string | Translation;
	description?: string | Translation;
	lang?: Language;
  seo?: {
    title?: Translation;
    description?: Translation;
    keywords?: Translation;
  }
}

const { lang = "en", seo } = Astro.props;
const siteData = await getSiteData();
const { companyInfo, header, footer } = siteData;

const t = createTranslate(lang);

const displayTitle = seo?.title ? t(seo.title) : (typeof Astro.props.title === 'string' ? Astro.props.title : (Astro.props.title ? t(Astro.props.title) : "Kellogg Fashion"));
const displayDescription = seo?.description ? t(seo.description) : (typeof Astro.props.description === 'string' ? Astro.props.description : (Astro.props.description ? t(Astro.props.description) : ""));
const displayKeywords = seo?.keywords ? t(seo.keywords) : "";

---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/logo/logo.jpg" />
		<meta name="generator" content={Astro.generator} />
		<title>{displayTitle}</title>
    <meta name="description" content={displayDescription} />
    {displayKeywords && <meta name="keywords" content={displayKeywords} />}
    
    <link rel="alternate" href="https://kellogg-fashion.com/" hreflang="x-default" />
    <link rel="alternate" href="https://kelloggfashion.com/usa-heavyweight-hoodie-manufacturer" hreflang="en-US" />
    <link rel="alternate" href="https://kelloggfashion.com/uk-streetwear-clothing-manufacturer" hreflang="en-UK" />
    <link rel="alternate" href="https://kelloggfashion.com/canada-blank-apparel-supplier" hreflang="en-CA" />
    <link rel="alternate" href="https://kelloggfashion.com/australia-heavyweight-tshirt-supplier" hreflang="en-AU" />

    <!-- Google Fonts or other assets can be added here -->
	</head>
	<body class="bg-background text-foreground selection:bg-primary/10">
    <Header 
      client:load 
      header={header} 
      companyInfo={companyInfo} 
      lang={lang} 
      pathname={Astro.url.pathname}
    />
    <TawkChat />
    
    <main class="mt-16 md:mt-20">
		  <slot />
    </main>

    <Footer 
      footer={footer} 
      companyInfo={companyInfo} 
      lang={lang} 
    />
	</body>
</html>

<style is:global>
  /* Custom global styles can go here */
  :root {
    --header-height: 4rem;
  }
  @media (min-width: 768px) {
    :root {
      --header-height: 5rem;
    }
  }
</style>
