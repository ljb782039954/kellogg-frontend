---
import type { CustomPage, Language, PageBlock } from "@core/types";
import { createRequestMemo, type RequestMemo } from "@core/lib/requestMemo";

type LoadBlockData = (options: {
  block: PageBlock;
  lang: Language;
  api: any;
  requestMemo: RequestMemo;
}) => Promise<Record<string, any>>;

interface Props {
  schema: CustomPage;
  lang: Language;
  api: any;
  blockRenderer: any;
  loadBlockData?: LoadBlockData;
}

const { schema, lang, api, blockRenderer: BlockRenderer, loadBlockData } = Astro.props;
const enabledBlocks = schema.blocks.filter((block) => block.isVisible);
const requestMemo = createRequestMemo();

// 预取所有需要数据的区块
const blocksWithData: any[] = await Promise.all(
  enabledBlocks.map(async (block) => {
    const data = loadBlockData
      ? await loadBlockData({ block, lang, api, requestMemo })
      : {};
    return { ...block, data };
  })
);

---

<div class="dynamic-page">
  {blocksWithData.map((block) => (
    <BlockRenderer block={block} lang={lang} />
  ))}
</div>
