---
import { api } from "@services/api";
import { currentSite, loadSitePage } from "@site-package";
import type { CmsCustomPage } from "@/cms/types";

const fixedPageIds = new Set([
  "products",
  "system-inquiry",
  "customer-reviews",
  "system-blog",
]);

export async function getStaticPaths() {
  const pages = await api.getConfig<CmsCustomPage[]>("pages");

  return (pages ?? [])
    .filter((item: CmsCustomPage) => !fixedPageIds.has(item.id) && item.type !== "fixed-layout")
    .map((page: CmsCustomPage) => {
      const normalizedPath = page.path === "/" ? undefined : page.path.replace(/^\/+/, "");
      return {
        params: { slug: normalizedPath },
        props: { pageId: page.id },
      };
    });
}

const CmsPage = await loadSitePage(currentSite.pages?.cms);
const { pageId } = Astro.props;

if (!CmsPage || !pageId) return Astro.redirect("/404");
---

<CmsPage pageId={pageId} />
