---
export const prerender = false;

import { SiteService } from "@services/siteService";
import { currentSite, loadSitePage } from "@site-package";

const CmsPage = await loadSitePage(currentSite.pages?.cms);
const slug = Array.isArray(Astro.params.slug)
  ? Astro.params.slug.join("/")
  : Astro.params.slug;
const requestPath = slug ? `/${slug}` : "/";
const { pages } = await SiteService.getSiteData(Astro);
const page = pages.find((item) => item.path === requestPath && item.id !== "products" && item.type !== "fixed-layout");

if (!CmsPage || !page) return Astro.redirect("/404");
---

<CmsPage pageId={page.id} />
