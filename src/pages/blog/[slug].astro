---
export const prerender = false;

import { currentSite, loadSitePage } from "@site-package";

const BlogDetailPage = await loadSitePage(currentSite.pages?.blogDetail);
const blogSlug = Astro.params.slug;

if (!BlogDetailPage || !blogSlug) return Astro.redirect("/404");
---

<BlogDetailPage blogSlug={blogSlug} />
