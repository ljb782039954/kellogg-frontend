---
import Layout from "../../layouts/Layout.astro";
import { api } from "../../lib/api";
import { SiteService } from "../../services/siteService";
import ProductDetailView from "../../components/product/ProductDetailView";
import ProductCustomFields from "../../components/product/ProductCustomFields.astro";
import ProductCard from "../../components/product/ProductCardStatic";
import SectionHeader from "../../components/SectionHeader";
import ProductVideo from "../../components/ProductVideo";
import type { Language, Product } from "../../types";
import { createTranslate } from "../../lib/i18n";

export const prerender = false;

Astro.response.headers.set('Cache-Control', 'public, max-age=60, s-maxage=300, stale-while-revalidate=600');

const { id } = Astro.params;
const { lang } = await SiteService.getSiteData(Astro);
const t = createTranslate(lang);

// Data Fetching
const [productRaw, productsRes, categories] = await Promise.all([
  api.getProduct(Number(id)),
  api.getProducts({ pageSize: 5 }),
  api.getCategories()
]);

if (!productRaw) {
  return Astro.redirect('/404');
}

// Map Category ID to Name Object
const categoryObj = categories.find(c => c.id === productRaw.category);
const product: Product = {
  ...productRaw,
  category: categoryObj ? categoryObj.name : productRaw.category
} as any;

const relatedProducts = productsRes.data
  .filter(p => String(p.id) !== String(id))
  .slice(0, 4);

const seo = {
  title: t(product.name),
  description: t(product.description),
  image: product.image
};
---

<Layout title={seo.title} lang={lang} seo={seo}>
  <main class="pt-32 pb-20">
    <div class="container mx-auto px-4">
      <!-- Breadcrumbs -->
      <nav class="flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-gray-300 mb-12 overflow-hidden whitespace-nowrap">
        <a href="/" class="hover:text-gray-900 transition-colors">{lang === 'zh' ? '首页' : 'Home'}</a>
        <span class="text-gray-200">/</span>
        <a href="/products" class="hover:text-gray-900 transition-colors">{lang === 'zh' ? '全部商品' : 'Products'}</a>
        <span class="text-gray-200">/</span>
        <span class="text-gray-900 truncate">{t(product.name)}</span>
      </nav>

      <!-- Main Product Section (React Island) -->
      <ProductDetailView product={product} lang={lang} client:load />

      <!-- Custom Fields (Static Astro) -->
      <ProductCustomFields customFields={product.customFields} lang={lang} />

      <!-- Video Section -->
      {product.videos && product.videos.length > 0 && (
        <section class="py-24 border-t border-gray-100">
          <div class="max-w-4xl mx-auto">
            <SectionHeader lang={lang} title={{ zh: '视频展示', en: 'Video Showcase' }} theme="light" />
            <div class="grid grid-cols-1 gap-12 mt-12">
              {product.videos.map((vid) => <ProductVideo url={vid} />)}
            </div>
          </div>
        </section>
      )}
    </div>

    <!-- Related Products -->
    {relatedProducts.length > 0 && (
      <section class="bg-gray-50/50 py-32 mt-20">
        <div class="container mx-auto px-4">
          <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6">
            <div>
              <h2 class="text-3xl md:text-5xl font-bold text-gray-900 mb-4">
                {lang === 'zh' ? '为您推荐' : 'Recommended'}
              </h2>
              <div class="w-20 h-1.5 bg-gray-900 rounded-full" />
            </div>
            <a href="/products" class="inline-flex items-center gap-2 font-black uppercase tracking-tighter text-gray-900 hover:gap-4 transition-all group">
              {lang === 'zh' ? '查看更多' : 'View More'}
              <svg class="w-6 h-6 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>

          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 md:gap-8">
            {relatedProducts.map((p) => (
              <a href={`/product/${p.id}`} class="block h-full">
                <ProductCard product={p} lang={lang} />
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>
</Layout>
