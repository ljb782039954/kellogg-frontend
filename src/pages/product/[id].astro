---
export const prerender = false;

import { currentSite, loadSitePage } from "@site-package";

Astro.response.headers.set("Cache-Control", "public, max-age=300, s-maxage=3600, stale-while-revalidate=86400");

const ProductDetailPage = await loadSitePage(currentSite.pages?.productDetail);
const { id } = Astro.params;

if (!ProductDetailPage || !id) return Astro.redirect("/404");
---

<ProductDetailPage id={id} />
