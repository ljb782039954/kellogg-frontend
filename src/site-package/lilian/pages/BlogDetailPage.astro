---
import Layout from "../layouts/SiteLayout.astro";
import BlogDetailView from "./blog/BlogDetailView.astro";
import { PageService } from "@core-webApp/services/pageService";
import { api } from "@services/api";
import { SiteService } from "@services/siteService";

interface Props {
  blogSlug: string;
}

const { blogSlug } = Astro.props;
const { lang } = await SiteService.getSiteData(Astro);
const pageData = await PageService.loadBlogDetailPageData({ blogSlug, api, lang });

if (!pageData.blog) {
  return Astro.redirect("/blog");
}

const { blog, relatedBlogs } = pageData;
const title = lang === "zh" ? blog.title_zh : blog.title_en;
const summary = lang === "zh" ? blog.summary_zh : blog.summary_en;
const seoTitle = (lang === "zh" ? blog.seo_title_zh : blog.seo_title_en) || title;
const seoDesc = (lang === "zh" ? blog.seo_desc_zh : blog.seo_desc_en) || summary || "";
---

<Layout title={seoTitle} description={seoDesc} lang={lang}>
  <BlogDetailView
    blog={blog}
    relatedBlogs={relatedBlogs}
    lang={lang}
    currentUrl={Astro.url.href}
  />
</Layout>
