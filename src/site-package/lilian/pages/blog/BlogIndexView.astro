---
import BlogGridContainer from "./BlogGridContainer";
import type { BlogSummary, Language, BlogGridSortId } from "@/cms/types";

interface Props {
  blogs: BlogSummary[];
  categories: string[];
  totalBlogs: number;
  initialPage: number;
  initialCategory: string;
  initialSort: BlogGridSortId;
  lang: Language;
}

const { blogs, categories, totalBlogs, initialPage, initialCategory, initialSort, lang } = Astro.props;
const t = (zh: string, en: string) => lang === "zh" ? zh : en;
---

<section class="border-b border-border bg-page">
  <div class="mx-auto max-w-6xl px-6 py-16 text-center md:py-20">
    <span class="text-[10px] uppercase tracking-[0.2em] text-subtle">
      {t("行业洞察", "Industry Insights")}
    </span>
    <h1 class="mt-4 font-luxury-heading text-4xl font-light leading-tight text-ink-strong md:text-5xl">
      {t("博客与资讯", "Blog & Resources")}
    </h1>
    <p class="mx-auto mt-4 max-w-xl text-sm leading-6 text-body md:text-base">
      {t("探索面料科学、制造技巧和行业趋势，助力您的品牌成长。", "Explore fabric science, manufacturing tips, and trends to grow your apparel brand.")}
    </p>
  </div>
</section>

<BlogGridContainer
  blogs={blogs}
  categories={categories}
  totalBlogs={totalBlogs}
  initialPage={initialPage}
  initialCategory={initialCategory}
  initialSort={initialSort}
  lang={lang}
  client:load
/>
