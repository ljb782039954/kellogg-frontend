---
import OptimizedImage from "@/core-webApp/components/OptimizedImage.astro";
import type { Blog, BlogSummary, Language } from "@/cms/types";
import { sanitizeCmsHtml } from "@/cms/lib/contentSecurity";
import "../../styles/blog-prose.css";

interface Props {
  blog: Blog;
  relatedBlogs: BlogSummary[];
  lang: Language;
  currentUrl: string;
}

const { blog, relatedBlogs, lang, currentUrl } = Astro.props;

function t(zh: string, en: string) {
  return lang === "zh" ? zh : en;
}

const title = lang === "zh" ? blog.title_zh : blog.title_en;
const content = lang === "zh" ? blog.content_zh : blog.content_en;

function formatDate(date: string | null) {
  if (!date) return "";
  return new Date(date).toLocaleDateString(lang === "zh" ? "zh-CN" : "en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

function getBlogTitle(item: BlogSummary) {
  return lang === "zh" ? item.title_zh : item.title_en;
}

const words = content
  ? lang === "zh"
    ? content.replace(/\s/g, "").length / 300
    : content.split(/\s+/).length / 200
  : 0;
const readingTime = Math.max(1, Math.round(words));

let htmlContent = "";
try {
  const { marked } = await import("marked");
  htmlContent = sanitizeCmsHtml(await marked.parse(content || ""));
} catch {
  htmlContent = sanitizeCmsHtml((content || "")
    .replace(/^### (.+)$/gm, "<h3>$1</h3>")
    .replace(/^## (.+)$/gm, "<h2>$1</h2>")
    .replace(/^# (.+)$/gm, "<h1>$1</h1>")
    .replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>")
    .replace(/\*(.+?)\*/g, "<em>$1</em>")
    .replace(/\n\n/g, "</p><p>")
    .replace(/^/, "<p>")
    .replace(/$/, "</p>"));
}
---

<nav class="mx-auto flex max-w-6xl items-center gap-2 px-6 py-5 text-[11px] uppercase tracking-[0.14em] text-subtle">
  <a href="/" class="transition-colors hover:text-ink-strong">{t("首页", "Home")}</a>
  <span>/</span>
  <a href="/blog" class="transition-colors hover:text-ink-strong">{t("博客", "Blog")}</a>
  <span>/</span>
  <span class="max-w-xs text-body line-clamp-1">{title}</span>
</nav>

{blog.cover_image && (
  <div class="mx-auto mb-10 max-w-6xl px-6">
    <div class="h-64 w-full overflow-hidden rounded-md bg-media md:h-96">
      <OptimizedImage
        src={blog.cover_image}
        alt={title}
        width={1200}
        class="w-full h-full object-cover"
      />
    </div>
  </div>
)}

<div class="mx-auto max-w-6xl px-6 pb-20">
  <div class="flex items-start gap-12">
    <article class="flex-1 min-w-0">
      <header class="mb-8">
        {blog.category && (
          <span class="mb-4 inline-block border border-border px-3 py-1 text-[10px] uppercase tracking-[0.16em] text-body">
            {blog.category}
          </span>
        )}
        <h1 class="mb-5 font-luxury-heading text-4xl font-light leading-tight text-ink-strong md:text-5xl">
          {title}
        </h1>

        <div class="flex flex-wrap items-center gap-3 border-b border-border pb-6 text-[11px] uppercase tracking-[0.1em] text-subtle">
          <div class="flex items-center gap-1.5">
            <div class="flex h-6 w-6 items-center justify-center rounded-full bg-page text-[10px] text-body">
              {blog.author[0].toUpperCase()}
            </div>
            <span>{blog.author}</span>
          </div>
          <span>·</span>
          <span>{formatDate(blog.publish_date || blog.created_at)}</span>
          <span>·</span>
          <span>{t(`${readingTime} 分钟阅读`, `${readingTime} min read`)}</span>
          <span>·</span>
          <span class="flex items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle>
            </svg>
            {blog.view_count.toLocaleString()}
            {t("次阅读", "views")}
          </span>
        </div>

        {blog.tags && blog.tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2">
            {blog.tags.map((tag) => (
              <span class="inline-flex items-center gap-1 border border-border px-2.5 py-1 text-[10px] uppercase tracking-[0.1em] text-subtle">
                # {tag}
              </span>
            ))}
          </div>
        )}
      </header>

      <div class="blog-prose" set:html={htmlContent} />

      <div class="mt-12 border-t border-border pt-8">
        <p class="mb-3 text-[10px] uppercase tracking-[0.16em] text-subtle">
          {t("分享这篇文章", "Share this article")}
        </p>
        <div class="flex flex-wrap gap-2">
          <a
            href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(currentUrl)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="border border-ink-strong bg-ink-strong px-4 py-2 text-xs text-on-dark transition-colors hover:bg-ink"
          >
            X (Twitter)
          </a>
          <a
            href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(currentUrl)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="border border-border bg-surface px-4 py-2 text-xs text-ink-strong transition-colors hover:border-ink-strong"
          >
            LinkedIn
          </a>
          <button
            id="copy-link-btn"
            class="border border-border bg-surface px-4 py-2 text-xs text-ink-strong transition-colors hover:border-ink-strong"
          >
            {t("复制链接", "Copy Link")}
          </button>
        </div>
      </div>
    </article>

    <aside class="sticky top-24 hidden w-64 shrink-0 space-y-6 lg:block">
      {relatedBlogs.length > 0 && (
        <div class="border border-border bg-surface p-5">
          <h3 class="mb-4 text-[10px] uppercase tracking-[0.16em] text-subtle">
            {t("相关文章", "Related Articles")}
          </h3>
          <div class="space-y-4">
            {relatedBlogs.slice(0, 3).map((item) => (
              <a href={`/blog/${item.slug}`} class="flex gap-3 group">
                <div class="h-14 w-14 shrink-0 overflow-hidden rounded-md bg-media">
                  {item.cover_image ? (
                    <OptimizedImage
                      src={item.cover_image}
                      alt={getBlogTitle(item)}
                      width={100}
                      class="w-full h-full object-cover"
                    />
                  ) : (
                    <div class="h-full w-full bg-page" />
                  )}
                </div>
                <div class="flex-1 min-w-0">
                  <p class="font-luxury-heading text-sm leading-snug text-ink-strong transition-colors group-hover:text-body line-clamp-2">
                    {getBlogTitle(item)}
                  </p>
                  <p class="mt-1 text-[10px] uppercase tracking-[0.1em] text-subtle">
                    {formatDate(item.publish_date || item.created_at)}
                  </p>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      <a
        href="/blog"
        class="flex w-full items-center justify-center gap-2 border border-ink-strong bg-ink-strong px-4 py-3 text-xs text-on-dark transition-colors hover:bg-ink"
      >
        ← {t("返回博客列表", "Back to Blog")}
      </a>
    </aside>
  </div>

  {relatedBlogs.length > 0 && (
    <section class="mt-16 border-t border-border pt-12">
      <h2 class="mb-8 font-luxury-heading text-3xl font-light text-ink-strong">
        {t("你可能也感兴趣", "You May Also Like")}
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {relatedBlogs.map((item) => (
          <a
            href={`/blog/${item.slug}`}
            class="group block overflow-hidden rounded-md border border-border bg-surface transition-colors hover:border-ink-strong"
          >
            <div class="aspect-[16/9] overflow-hidden bg-media">
              {item.cover_image ? (
                <OptimizedImage
                  src={item.cover_image}
                  alt={getBlogTitle(item)}
                  width={600}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              ) : (
                <div class="h-full w-full bg-page" />
              )}
            </div>
            <div class="p-4">
              {item.category && (
                <span class="text-[10px] uppercase tracking-[0.14em] text-subtle">
                  {item.category}
                </span>
              )}
              <h3 class="mt-2 font-luxury-heading text-base leading-snug text-ink-strong transition-colors group-hover:text-body line-clamp-2">
                {getBlogTitle(item)}
              </h3>
              <p class="mt-2 text-[10px] uppercase tracking-[0.1em] text-subtle">
                {formatDate(item.publish_date || item.created_at)}
              </p>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}
</div>

<style>
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  const copyBtn = document.getElementById("copy-link-btn");
  copyBtn?.addEventListener("click", async () => {
    try {
      await navigator.clipboard.writeText(window.location.href);
      if (copyBtn) {
        const original = copyBtn.textContent || "";
        copyBtn.textContent = "✓ Copied!";
        setTimeout(() => {
          copyBtn.textContent = original;
        }, 2000);
      }
    } catch {
      const input = document.createElement("input");
      input.value = window.location.href;
      document.body.appendChild(input);
      input.select();
      document.execCommand("copy");
      document.body.removeChild(input);
    }
  });
</script>
