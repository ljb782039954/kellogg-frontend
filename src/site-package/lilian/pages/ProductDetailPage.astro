---
import Layout from "../layouts/SiteLayout.astro";
import ProductDetailView from "./productDetail/ProductDetailView";
import VideoEmbed, { getVideoEmbedSource } from "@/runtime/components/VideoEmbed";
import { ProductCard, ProductCustomFields, SectionHeader } from "../components/base";
import { PageService } from "@core-webApp/services/pageService";
import { api } from "@services/api";
import { SiteService } from "@services/siteService";
import type { Product } from "@/cms/types";
import { createTranslate } from "../utils/i18n";

interface Props {
  id: string;
}

const { id } = Astro.props;
const { lang } = await SiteService.getSiteData(Astro);
const t = createTranslate(lang);

const pageData = await PageService.loadProductDetailPageData({
  id: Number(id),
  api,
  lang,
});

if (!pageData.product) {
  return Astro.redirect("/404");
}

const product: Product = {
  ...pageData.product,
  category: pageData.product.categoryName || pageData.product.category,
} as any;

const productVideoUrls = (product.videos || []).filter((url) => Boolean(getVideoEmbedSource(url)));

const seo = {
  title: t(product.name),
  description: t(product.description),
  image: product.image,
};
---

<Layout title={seo.title} lang={lang} seo={seo}>
  <main class="pb-20">
    <div class="mx-auto max-w-7xl px-6">
      <nav class="mb-8 flex items-center gap-2 overflow-hidden whitespace-nowrap py-5 text-[11px] uppercase tracking-[0.14em] text-subtle">
        <a href="/" class="transition-colors hover:text-ink-strong">{lang === "zh" ? "首页" : "Home"}</a>
        <span>/</span>
        <a href="/products" class="transition-colors hover:text-ink-strong">{lang === "zh" ? "全部商品" : "Products"}</a>
        <span>/</span>
        <span class="truncate text-body">{t(product.name)}</span>
      </nav>

      <ProductDetailView product={product} lang={lang} client:load />

      <ProductCustomFields customFields={product.customFields} lang={lang} />

      {productVideoUrls.length > 0 && (
        <section class="border-t border-border py-16">
          <div class="mx-auto max-w-4xl">
            <SectionHeader titleText={t({ zh: "视频展示", en: "Video Showcase" })} theme="light" />
            <div class="mt-10 grid grid-cols-1 gap-10">
              {productVideoUrls.map((url) => <VideoEmbed url={url} title={t(product.name)} />)}
            </div>
          </div>
        </section>
      )}
    </div>

    {pageData.relatedProducts.length > 0 && (
      <section class="mt-20 border-y border-border bg-page py-16">
        <div class="mx-auto max-w-7xl px-6">
          <div class="mb-10 flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
            <div>
              <h2 class="font-luxury-heading text-3xl font-light text-ink-strong md:text-4xl">
                {lang === "zh" ? "为您推荐" : "Recommended"}
              </h2>
            </div>
            <a href="/products" class="group inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.14em] text-body transition-colors hover:text-ink-strong">
              {lang === "zh" ? "查看更多" : "View More"}
              <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>

          <div class="grid grid-cols-2 gap-5 md:grid-cols-3 lg:grid-cols-4 lg:gap-6">
            {pageData.relatedProducts.map((item) => (
              <ProductCard product={item} lang={lang} />
            ))}
          </div>
        </div>
      </section>
    )}
  </main>
</Layout>
