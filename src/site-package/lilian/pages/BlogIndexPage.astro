---
import Layout from "../layouts/SiteLayout.astro";
import { api } from "@services/api";
import { SiteService } from "@services/siteService";
import type { BlogSummary } from "@/cms/types";
import MainHeading from "../components/blocks/MainHeading";
import BlogGridContainer from "../components/blocks-containers/BlogGridContainer";

const siteData = await SiteService.getSiteData(Astro);
const { lang } = siteData;

let blogs: BlogSummary[] = [];
try {
  const resp = await api.getBlogs({ page: 1, pageSize: 100, sort: "newest" });
  blogs = resp.data || [];
} catch (error) {
  console.error("[Blog Index SSR] Failed to fetch blogs:", error);
}

let blogPageDetail: any = null;
try {
  blogPageDetail = await api.getPageById("system-blog");
} catch (error) {
  console.error("[Blog Index SSR] Failed to fetch system-blog page details:", error);
}

const blogSEO = blogPageDetail?.seo || {
  title: { zh: "博客与资讯 - Lilian Fashion", en: "Blog & Resources - Lilian Fashion" },
  description: {
    zh: "浏览 Lilian Fashion 博客，获取最新行业资讯、面料指南、服装制造技巧和流行趋势报告。",
    en: "Explore Lilian Fashion blog for industry news, fabric guides, OEM tips, and trend reports from a leading apparel manufacturer.",
  },
};
---

<Layout seo={blogSEO} lang={lang}>
  <main class="py-12 bg-surface min-h-[60vh]">
    <MainHeading
      titleText={lang === "zh" ? blogPageDetail?.title?.zh || "博客与资讯" : blogPageDetail?.title?.en || "Blog & Resources"}
      subtitleText={lang === "zh" ? blogPageDetail?.subtitle?.zh || "行业洞察" : blogPageDetail?.subtitle?.en || "Industry Insights"}
      lang={lang}
    />

    <BlogGridContainer
      blogs={blogs}
      lang={lang}
      maxItems={-1}
      client:load
    />
  </main>
</Layout>

