---
import Layout from "../layouts/SiteLayout.astro";
import CustomerReviews from "./customerReviews/CustomerReviews";
import { toCustomerReviewsViewProps } from "./customerReviews/customerReviewsAdapter";
import { api } from "@services/api";
import { lilianSiteConfig } from "../config";
import { SiteService } from "@services/siteService";

const siteData = await SiteService.getSiteData(Astro);
const { lang } = siteData;

let customerReviewsPage: any = null;
let reviews: any[] = [];
try {
  [customerReviewsPage, reviews] = await Promise.all([
    api.getPageById("customer-reviews"),
    api.getReviews(),
  ]);
} catch (error) {
  console.error("[Customer Reviews SSR] Failed to fetch customer-reviews page details:", error);
}

const pageSEO = customerReviewsPage?.seo || {
  title: { zh: "客户评价 - Lilian", en: "Customer Reviews - Lilian" },
  description: {
    zh: "来自全球客户的真实反馈与合作评价。",
    en: "Real feedback and partnership reviews from customers around the world.",
  },
};
const customerReviewsProps = toCustomerReviewsViewProps(lilianSiteConfig, reviews, lang);
---

<Layout seo={pageSEO} lang={lang}>
  <section class="border-b border-border bg-page">
    <div class="mx-auto max-w-6xl px-6 py-16 text-center md:py-20">
      <span class="text-[10px] uppercase tracking-[0.2em] text-subtle">
        {lang === "zh" ? "客户见证" : "Testimonials"}
      </span>
      <h1 class="mt-4 font-luxury-heading text-4xl font-light leading-tight text-ink-strong md:text-5xl">
        {lang === "zh" ? "客户评价" : "Customer Reviews"}
      </h1>
      <p class="mx-auto mt-4 max-w-xl text-sm leading-6 text-body md:text-base">
        {lang === "zh" ? "听听来自全球合作伙伴的真实反馈，见证高品质服装制造。" : "Real feedback from global partners, witnessing premium apparel manufacturing."}
      </p>
    </div>
  </section>

  <CustomerReviews
    {...customerReviewsProps}
    totalText={lang === "zh" ? `共 ${reviews.length} 条评价` : `${reviews.length} reviews total`}
    client:load
  />
</Layout>
