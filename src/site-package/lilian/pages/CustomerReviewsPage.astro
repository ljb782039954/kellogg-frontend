---
import Layout from "../layouts/SiteLayout.astro";
import CustomerReviews from "./customerReviews/CustomerReviews";
import { toCustomerReviewsViewProps } from "./customerReviews/adapter";
import { api } from "@services/api";
import { SiteService } from "@services/siteService";
import MainHeading from "../components/blocks/MainHeading";

const siteData = await SiteService.getSiteData(Astro);
const { lang } = siteData;

let customerReviewsPage: any = null;
let reviews: any[] = [];
try {
  [customerReviewsPage, reviews] = await Promise.all([
    api.getPageById("customer-reviews"),
    api.getReviews(),
  ]);
} catch (error) {
  console.error("[Customer Reviews SSR] Failed to fetch customer-reviews page details:", error);
}

const pageSEO = customerReviewsPage?.seo || {
  title: { zh: "客户评价 - Lilian Fashion", en: "Customer Reviews - Lilian Fashion" },
  description: {
    zh: "来自全球品牌买家的真实穿搭视频与成衣评价，见证 Lilian Fashion 的服装制造品质。",
    en: "Real try-on videos and honest client reviews from global brand buyers — see Lilian Fashion apparel quality in action.",
  },
};
const customerReviewsProps = toCustomerReviewsViewProps(reviews, lang);
---

<Layout seo={pageSEO} lang={lang}>
  <main class="py-12 bg-surface min-h-[60vh]">
    <MainHeading
      titleText={lang === "zh" ? "客户评价" : "Customer Reviews"}
      subtitleText={lang === "zh" ? "客户见证" : "Testimonials"}
      descriptionText={lang === "zh" ? "听听来自全球合作伙伴的真实反馈，见证高品质服装制造。" : "Real feedback from global partners, witnessing premium apparel manufacturing."}
      lang={lang}
    />
    
    <CustomerReviews {...customerReviewsProps} />
  </main>
</Layout>
