---
import Layout from "../layouts/SiteLayout.astro";
import DynamicRenderer from "@core-webApp/components/DynamicRenderer.astro";
import BlockRenderer from "../services/BlockRenderer.astro";
import { api } from "@services/api";
import { SiteService } from "@services/siteService";
import { loadLilianBlockData } from "../services/loadBlockData";

interface Props {
  pageId: string;
}

const { pageId } = Astro.props;
const siteData = await SiteService.getSiteData(Astro);
const { lang } = siteData;
const fullPage = await api.getPageById(pageId);

if (!fullPage) {
  console.error(`[Astro] Page not found for ID: ${pageId}`);
  return Astro.redirect("/");
}
---

<Layout title={fullPage.title} lang={lang} seo={fullPage.seo}>
  <DynamicRenderer
    schema={fullPage}
    lang={lang}
    api={api}
    blockRenderer={BlockRenderer}
    loadBlockData={loadLilianBlockData}
    url={Astro.url}
  />
</Layout>
