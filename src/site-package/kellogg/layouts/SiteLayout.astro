---
import "../styles/global.css";
import { SiteService } from "../../../services/siteService";
import Header from "../components/Header";
import Footer from "../components/Footer";
import TawkChat from "../components/TawkChat";
import { createTranslate } from "../utils/i18n";
import { kelloggSiteConfig } from "../config";
import type { Translation, Language } from "../types";
import InquirySection from "../components/blocks/InquirySection";

interface Props {
  title?: string | Translation;
  description?: string | Translation;
  lang?: Language;
  hideInquiry?: boolean;
  seo?: {
    title?: string | Translation;
    description?: string | Translation;
    keywords?: string | Translation;
  };
}

const { lang = kelloggSiteConfig.defaultLanguage, seo, hideInquiry = false } = Astro.props;
const siteData = await SiteService.getSiteData(Astro);
const {
  companyInfo,
  header,
  footer,
  lang: detectedLang,
  exchangeRates,
} = siteData;

const t = createTranslate(lang);

// 自动检测是否为询盘页面
const isInquiryPage = Astro.url.pathname.includes('/inquiry') || hideInquiry;

const displayTitle = seo?.title
// ... (lines 34-47 remain the same)
  ? t(seo.title)
  : typeof Astro.props.title === "string"
    ? Astro.props.title
    : Astro.props.title
      ? t(Astro.props.title)
      : kelloggSiteConfig.seo?.defaultTitle || kelloggSiteConfig.displayName;
const displayDescription = seo?.description
  ? t(seo.description)
  : typeof Astro.props.description === "string"
    ? Astro.props.description
    : Astro.props.description
      ? t(Astro.props.description)
      : "";
const displayKeywords = seo?.keywords ? t(seo.keywords) : "";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <link rel="icon" type="image/svg+xml" href="/logo/logo.jpg" />
    <meta name="generator" content={Astro.generator} />
    <title>{displayTitle}</title>
    <meta name="description" content={displayDescription} />
    {displayKeywords && <meta name="keywords" content={displayKeywords} />}

    {kelloggSiteConfig.seo?.alternates?.map((alternate) => (
      <link rel="alternate" href={alternate.href} hreflang={alternate.hreflang} />
    ))}

    <!-- Google Fonts or other assets can be added here -->
    <script is:inline define:vars={{ initialRates: exchangeRates?.rates }}>
      window.__EXCHANGE_RATES__ = initialRates;
    </script>
  </head>
  <body class="bg-background text-foreground selection:bg-primary/10">
    <Header
      client:idle
      header={header}
      companyInfo={companyInfo}
      lang={lang}
      pathname={Astro.url.pathname}
      initialRates={exchangeRates?.rates}
    />
    <TawkChat lang={lang} />

    <main class="mt-16 md:mt-20">
      <slot />
      {!isInquiryPage && <InquirySection lang={lang} client:visible />}
    </main>

    <Footer footer={footer} companyInfo={companyInfo} lang={lang} />
  </body>
</html>

<style is:global>
  /* Custom global styles can go here */
  :root {
    --header-height: 4rem;
  }
  @media (min-width: 768px) {
    :root {
      --header-height: 5rem;
    }
  }
</style>

<script>
  import { initPriceTracker } from "../../../core/lib/priceTracker";
  initPriceTracker();
</script>
