---
import { Mail, Phone, MapPin,} from "lucide-react";
import type { FooterContent, CompanyInfo, Language } from "@core/types";
import SocialLinks from "./SocialLinks.astro";
import { createTranslate } from "../utils/i18n";


interface Props {
  footer: FooterContent;
  companyInfo: CompanyInfo;
  lang: Language;
}

const { footer, companyInfo, lang } = Astro.props;
const t = createTranslate(lang);

const themeStyles = {
  light: {
    bg: "bg-gray-900",
    text: "text-white",
    textMuted: "text-gray-400",
    border: "border-gray-800",
    link: "text-gray-400 hover:text-white",
    input: "bg-gray-800 border-gray-700 text-white",
    button: "bg-white text-gray-900 hover:bg-gray-100",
  },
};

const style = themeStyles["light"];
---

<footer id="footer" class={`${style.bg} pt-16 pb-8`}>
  <div class="container mx-auto px-4">
    <div
      class="grid grid-cols-[repeat(auto-fit,minmax(250px,1fr))] gap-8 mb-12"
    >
      <!-- Brand & Newsletter -->
      <div class="order-2 md:order-2 lg:order-1 lg:col-span-1">
        <h3 class={`text-2xl font-bold mb-4 ${style.text}`}>
          {t(companyInfo.name)}
        </h3>
        <p class={`mb-6 ${style.textMuted}`}>
          {t(companyInfo.description)}
        </p>

        <!-- Newsletter -->
        <div class="flex gap-2">
          <input
            type="email"
            placeholder={t(footer.newsletterPlaceholder)}
            class={`flex-1 px-4 py-2 rounded-lg border focus:outline-none focus:ring-2 ${style.input}`}
          />
          <button
            class={`px-4 py-2 rounded-lg font-medium transition-all ${style.button}`}
          >
            {t(footer.newsletterButton)}
          </button>
        </div>
      </div>

      <!-- Link Groups -->
      <div
        class="order-1 md:order-1 lg:order-2 lg:col-span-2 grid grid-cols-3 gap-4 md:gap-8"
      >
        {
          footer.linkGroups.map((group) => (
            <div>
              <h4 class={`text-lg font-semibold mb-4 ${style.text}`}>
                {t(group.title)}
              </h4>
              <ul class="space-y-2">
                {group.links.map((link) => (
                  <li>
                    {link.href === "#" ? (
                      <span class={`cursor-default ${style.link} opacity-50`}>
                        {t(link.name)}
                      </span>
                    ) : link.href.startsWith("/") ? (
                      <a
                        href={link.href}
                        class={`transition-colors ${style.link}`}
                      >
                        {t(link.name)}
                      </a>
                    ) : (
                      <a
                        href={link.href}
                        target="_blank"
                        rel="noopener noreferrer"
                        class={`transition-colors ${style.link}`}
                      >
                        {t(link.name)}
                      </a>
                    )}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>

      <!-- Contact Info -->
      <div class="order-3 md:order-2 lg:order-3 lg:col-span-1">
        <h4 class={`text-lg font-semibold mb-4 ${style.text}`}>
          {lang === "zh" ? "联系我们" : "Contact Us"}
        </h4>
        <ul class="space-y-3">
          <li class={`flex items-center gap-3 ${style.textMuted}`}>
            <Phone size={20} />
            <span>{companyInfo.contact.phone}</span>
          </li>
          <li class={`flex items-center gap-3 ${style.textMuted}`}>
            <Mail size={20} />
            <span>{companyInfo.contact.email}</span>
          </li>
          <li class={`flex items-start gap-3 ${style.textMuted}`}>
            <MapPin size={20} className="mt-0.5" />
            <span>{t(companyInfo.contact.address)}</span>
          </li>
        </ul>

        <SocialLinks socialLinks={companyInfo.socialMedia} />
      </div>
    </div>

    <!-- Divider -->
    <div class={`border-t ${style.border} pt-8`}>
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <p class={`text-sm ${style.textMuted}`}>
          © 2024 {t(companyInfo.name)}. {
            lang === "zh" ? "保留所有权利。" : "All rights reserved."
          }
        </p>
        <div class={`flex gap-6 text-sm ${style.textMuted}`}>
          <a href="#" class="hover:underline">
            {lang === "zh" ? "隐私政策" : "Privacy Policy"}
          </a>
          <a href="#" class="hover:underline">
            {lang === "zh" ? "服务条款" : "Terms of Service"}
          </a>
          <a href="#" class="hover:underline">
            {lang === "zh" ? "Cookie设置" : "Cookie Settings"}
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
