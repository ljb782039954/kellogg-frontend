---
// import type { Language } from "@/cms/types";
// import type { PageBlock } from "../types";
import {
  BrandValues,
  Carousel,
  Categories,
  CtaBanner,
  FAQ,
  FeaturedProducts,
  FeatureList,
  Gallery,
  ImageBanner,
  ImageBannerTag,
  ImageFull,
  ImageText,
  NewArrivals,
  PartnerLogos,
  Statistics,
  Testimonials,
  TextSection,
  Table,
  VideoSection,
} from "../components/blocks";
import {
  ProductGrid as ProductGridContainer,
} from "../components/blocks-containers";
import InquirySection from "../components/inquiry/InquirySection";
import type { BlockType } from "../types";


const { block, lang, api } = Astro.props;
const content = block.content ?? {};
const data = block.data ?? {};
const getImageUrl = (src: string, width: number) => api.getOptimizedImageUrl(src, width);

const renderedBlockTypes = {
  imageBanner: true,
  textSection: true,
  carousel: true,
  categories: true,
  productGrid: true,
  featuredProducts: true,
  newArrivals: true,
  brandValues: true,
  statistics: true,
  testimonials: true,
  faq: true,
  imageText: true,
  ctaBanner: true,
  featureList: true,
  gallery: true,
  imageBannerTag: true,
  imageFull: true,
  partnerLogos: true,
  table: true,
  videoSection: true,
  inquiry: true,
} satisfies Record<BlockType, true>;

const knownBlockTypes = new Set(Object.keys(renderedBlockTypes));
---

{block.type === "imageBanner" && <ImageBanner content={content as any} lang={lang} />}
{block.type === "textSection" && <TextSection content={content as any} lang={lang} />}
{block.type === "carousel" && <Carousel content={content as any} lang={lang} client:load />}
{block.type === "categories" && <Categories content={content as any} categories={data.categories}  lang={lang} />}
{block.type === "productGrid" && <ProductGridContainer {...content} {...data} lang={lang} client:load />}
{block.type === "featuredProducts" && <FeaturedProducts {...content} {...data} lang={lang} />}
{block.type === "newArrivals" && <NewArrivals {...content} {...data} lang={lang} />}
{block.type === "brandValues" && <BrandValues {...content as any} lang={lang} />}  
{block.type === "statistics" && <Statistics content={content as any} lang={lang} client:visible />}
{block.type === "testimonials" && <Testimonials content={content as any} lang={lang} />}
{block.type === "faq" && <FAQ content={content as any} lang={lang} client:visible />}
{block.type === "imageText" && <ImageText content={content as any} lang={lang} />}
{block.type === "ctaBanner" && <CtaBanner content={content as any} getImageUrl={getImageUrl} lang={lang} />}
{block.type === "featureList" && <FeatureList content={content as any} lang={lang} />}
{block.type === "gallery" && <Gallery content={content as any} lang={lang} client:visible />}
{block.type === "imageBannerTag" && <ImageBannerTag content={content as any} getImageUrl={getImageUrl} lang={lang} />}
{block.type === "imageFull" && <ImageFull content={content as any} lang={lang} client:visible />}
{block.type === "partnerLogos" && <PartnerLogos content={content as any} lang={lang} />}
{block.type === "videoSection" && <VideoSection content={content as any} lang={lang} />}
{block.type === "table" && <Table content={content as any} lang={lang} />}
{block.type === "inquiry" && <InquirySection lang={lang} client:visible />}

{!knownBlockTypes.has(block.type) && import.meta.env.DEV && (
  <div class="py-10 border-b border-dashed border-gray-200">
    <div class="container mx-auto px-4">
      <p class="text-gray-400 text-sm">
        [Block: {block.type}] (待迁移实现)
      </p>
      <pre class="bg-gray-100 p-4 rounded mt-2 text-xs overflow-auto max-h-40">
        {JSON.stringify(block.content, null, 2)}
      </pre>
    </div>
  </div>
)}
