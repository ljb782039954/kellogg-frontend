---
import type { Language, PageBlock } from "../types";

import ImageBanner from "../components/blocks/ImageBanner";
import TextSection from "../components/blocks/TextSection";
import Carousel from "../components/blocks/Carousel";
import Categories from "../components/blocks/Categories";
import ProductGrid from "../components/blocks/ProductGrid";
import FeaturedProducts from "../components/blocks/FeaturedProducts";
import InquirySection from "../components/blocks/InquirySection";
import BrandValues from "../components/blocks/BrandValues";
import Statistics from "../components/blocks/Statistics";
import Testimonials from "../components/blocks/Testimonials";
import FAQ from "../components/blocks/FAQ";
import ImageText from "../components/blocks/ImageText";
import CtaBanner from "../components/blocks/CtaBanner";
import FeatureList from "../components/blocks/FeatureList";
import NewArrivals from "../components/blocks/NewArrivals";
import Countdown from "../components/blocks/Countdown";
import Gallery from "../components/blocks/Gallery";
import ImageBannerTag from "../components/blocks/ImageBannerTag";
import ImageFull from "../components/blocks/ImageFull";
import PartnerLogos from "../components/blocks/PartnerLogos";
import VideoSection from "../components/blocks/VideoSection";
import CustomerReviews from "../components/blocks/CustomerReviews";

type BlockWithData = PageBlock & {
  data?: Record<string, any>;
};

interface Props {
  block: BlockWithData;
  lang: Language;
}

const { block, lang } = Astro.props;
const content = block.content ?? {};
const data = block.data ?? {};
const knownBlockTypes = new Set([
  "imageBanner",
  "textSection",
  "carousel",
  "categories",
  "productGrid",
  "featuredProducts",
  "newArrivals",
  "inquiry",
  "brandValues",
  "statistics",
  "testimonials",
  "faq",
  "imageText",
  "ctaBanner",
  "featureList",
  "countdown",
  "gallery",
  "imageBannerTag",
  "imageFull",
  "partnerLogos",
  "videoSection",
  "caseStudies",
]);
---

{block.type === "imageBanner" && <ImageBanner {...content} lang={lang} />}
{block.type === "textSection" && <TextSection {...content} lang={lang} />}
{block.type === "carousel" && <Carousel {...content} lang={lang} client:load />}
{block.type === "categories" && <Categories {...content} {...data} lang={lang} />}
{block.type === "productGrid" && <ProductGrid {...content} {...data} lang={lang} client:load />}
{block.type === "featuredProducts" && <FeaturedProducts {...content} {...data} lang={lang} />}
{block.type === "newArrivals" && <NewArrivals {...content} {...data} lang={lang} />}
{block.type === "inquiry" && <InquirySection lang={lang} client:visible />}
{block.type === "brandValues" && <BrandValues {...content} lang={lang} />}
{block.type === "statistics" && <Statistics {...content} lang={lang} client:visible />}
{block.type === "testimonials" && <Testimonials {...content} lang={lang} />}
{block.type === "faq" && <FAQ {...content} lang={lang} client:visible />}
{block.type === "imageText" && <ImageText {...content} lang={lang} />}
{block.type === "ctaBanner" && <CtaBanner {...content} lang={lang} />}
{block.type === "featureList" && <FeatureList {...content} lang={lang} />}
{block.type === "countdown" && <Countdown {...content} lang={lang} client:load />}
{block.type === "gallery" && <Gallery {...content} lang={lang} client:visible />}
{block.type === "imageBannerTag" && <ImageBannerTag {...content} lang={lang} />}
{block.type === "imageFull" && <ImageFull {...content} lang={lang} client:visible />}
{block.type === "partnerLogos" && <PartnerLogos {...content} lang={lang} />}
{block.type === "videoSection" && <VideoSection {...content} lang={lang} />}
{block.type === "caseStudies" && <CustomerReviews {...data} lang={lang} />}

{!knownBlockTypes.has(block.type) && import.meta.env.DEV && (
  <div class="py-10 border-b border-dashed border-gray-200">
    <div class="container mx-auto px-4">
      <p class="text-gray-400 text-sm">
        [Block: {block.type}] (待迁移实现)
      </p>
      <pre class="bg-gray-100 p-4 rounded mt-2 text-xs overflow-auto max-h-40">
        {JSON.stringify(block.content, null, 2)}
      </pre>
    </div>
  </div>
)}
