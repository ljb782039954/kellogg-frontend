---
import type { Language } from "@/cms/types";
import type { PageBlock } from "../types";
import {
  toBrandValuesViewProps,
  toCategoriesViewProps,
  toCarouselViewProps,
  toCountdownViewProps,
  toCtaBannerViewProps,
  toFAQViewProps,
  toFeatureListViewProps,
  toGalleryViewProps,
  toImageBannerTagViewProps,
  toImageBannerViewProps,
  toImageFullViewProps,
  toImageTextViewProps,
  toPartnerLogosViewProps,
  toStatisticsViewProps,
  toTestimonialsViewProps,
  toTextSectionViewProps,
  toVideoSectionViewProps,
} from "../block-adapters";
import type {
  BrandValuesContent,
  CategoriesContent,
  CarouselContent,
  CountdownContent,
  CtaBannerContent,
  FAQContent,
  FeatureListContent,
  GalleryContent,
  ImageBannerContent,
  ImageBannerTagContent,
  ImageFullContent,
  ImageTextContent,
  PartnerLogosContent,
  StatisticsContent,
  TestimonialsContent,
  TextSectionContent,
  VideoSectionContent,
} from "../block-adapters";

import {
  BrandValues,
  Carousel,
  Categories,
  Countdown,
  CtaBanner,
  FAQ,
  FeatureList,
  Gallery,
  ImageBanner,
  ImageBannerTag,
  ImageFull,
  ImageText,
  PartnerLogos,
  Statistics,
  Testimonials,
  TextSection,
  VideoSection,
} from "../components/blocks";
import {
  FeaturedProducts,
  InquirySection,
  NewArrivals,
  ProductGrid as ProductGridContainer,
} from "../components/blocks-containers";

type BlockWithData = PageBlock & {
  data?: Record<string, any>;
};

interface Props {
  block: BlockWithData;
  lang: Language;
  api: {
    getOptimizedImageUrl: (src: string, width: number) => string;
  };
}

const { block, lang, api } = Astro.props;
const content = block.content ?? {};
const data = block.data ?? {};
const getImageUrl = (src: string, width: number) => api.getOptimizedImageUrl(src, width);
const imageBannerProps = block.type === "imageBanner"
  ? toImageBannerViewProps(content as ImageBannerContent, lang)
  : {};
const imageBannerTagProps = block.type === "imageBannerTag"
  ? toImageBannerTagViewProps(content as ImageBannerTagContent, { lang, getImageUrl })
  : {};
const textSectionProps = block.type === "textSection"
  ? toTextSectionViewProps(content as TextSectionContent, lang)
  : {};
const brandValuesProps = block.type === "brandValues"
  ? toBrandValuesViewProps(content as BrandValuesContent, lang)
  : {};
const categoriesProps = block.type === "categories"
  ? toCategoriesViewProps(content as CategoriesContent, { categories: data.categories ?? [], lang })
  : {};
const carouselProps = block.type === "carousel"
  ? toCarouselViewProps(content as CarouselContent, lang)
  : {};
const countdownProps = block.type === "countdown"
  ? toCountdownViewProps(content as CountdownContent, lang)
  : {};
const ctaBannerProps = block.type === "ctaBanner"
  ? toCtaBannerViewProps(content as CtaBannerContent, { lang, getImageUrl })
  : {};
const imageTextProps = block.type === "imageText"
  ? toImageTextViewProps(content as ImageTextContent, lang)
  : {};
const featureListProps = block.type === "featureList"
  ? toFeatureListViewProps(content as FeatureListContent, lang)
  : {};
const testimonialsProps = block.type === "testimonials"
  ? toTestimonialsViewProps(content as TestimonialsContent, lang)
  : {};
const faqProps = block.type === "faq"
  ? toFAQViewProps(content as FAQContent, lang)
  : {};
const galleryProps = block.type === "gallery"
  ? toGalleryViewProps(content as GalleryContent, lang)
  : {};
const partnerLogosProps = block.type === "partnerLogos"
  ? toPartnerLogosViewProps(content as PartnerLogosContent, lang)
  : {};
const imageFullProps = block.type === "imageFull"
  ? toImageFullViewProps(content as ImageFullContent, lang)
  : {};
const videoSectionProps = block.type === "videoSection"
  ? toVideoSectionViewProps(content as VideoSectionContent, lang)
  : {};
const statisticsProps = block.type === "statistics"
  ? toStatisticsViewProps(content as StatisticsContent, lang)
  : {};
const knownBlockTypes = new Set([
  "imageBanner",
  "textSection",
  "carousel",
  "categories",
  "productGrid",
  "featuredProducts",
  "newArrivals",
  "brandValues",
  "statistics",
  "testimonials",
  "faq",
  "imageText",
  "ctaBanner",
  "featureList",
  "countdown",
  "gallery",
  "imageBannerTag",
  "imageFull",
  "partnerLogos",
  "videoSection",
  // fixed
  "inquiry",
]);
---

{block.type === "imageBanner" && <ImageBanner {...imageBannerProps} />}
{block.type === "textSection" && <TextSection {...textSectionProps} />}
{block.type === "carousel" && <Carousel {...carouselProps} client:load />}
{block.type === "categories" && <Categories {...categoriesProps} />}
{block.type === "productGrid" && <ProductGridContainer {...content} {...data} lang={lang} client:load />}
{block.type === "featuredProducts" && <FeaturedProducts {...content} {...data} lang={lang} />}
{block.type === "newArrivals" && <NewArrivals {...content} {...data} lang={lang} />}
{block.type === "brandValues" && <BrandValues {...brandValuesProps} />}
{block.type === "statistics" && <Statistics {...statisticsProps} client:visible />}
{block.type === "testimonials" && <Testimonials {...testimonialsProps} />}
{block.type === "faq" && <FAQ {...faqProps} client:visible />}
{block.type === "imageText" && <ImageText {...imageTextProps} />}
{block.type === "ctaBanner" && <CtaBanner {...ctaBannerProps} />}
{block.type === "featureList" && <FeatureList {...featureListProps} />}
{block.type === "countdown" && <Countdown {...countdownProps} client:load />}
{block.type === "gallery" && <Gallery {...galleryProps} client:visible />}
{block.type === "imageBannerTag" && <ImageBannerTag {...imageBannerTagProps} />}
{block.type === "imageFull" && <ImageFull {...imageFullProps} client:visible />}
{block.type === "partnerLogos" && <PartnerLogos {...partnerLogosProps} />}
{block.type === "videoSection" && <VideoSection {...videoSectionProps} />}
{block.type === "inquiry" && <InquirySection lang={lang} client:visible />}

{!knownBlockTypes.has(block.type) && import.meta.env.DEV && (
  <div class="py-10 border-b border-dashed border-gray-200">
    <div class="container mx-auto px-4">
      <p class="text-gray-400 text-sm">
        [Block: {block.type}] (待迁移实现)
      </p>
      <pre class="bg-gray-100 p-4 rounded mt-2 text-xs overflow-auto max-h-40">
        {JSON.stringify(block.content, null, 2)}
      </pre>
    </div>
  </div>
)}
