---
import Layout from "../layouts/SiteLayout.astro";
import BlogIndexView from "./blog/BlogIndexView.astro";
import { PageService } from "@core-webApp/services/pageService";
import { parseBlogGridSearchParams } from "@core-webApp/lib/blogGrid";
import { api } from "@services/api";
import { SiteService } from "@services/siteService";

const siteData = await SiteService.getSiteData(Astro);
const { lang } = siteData;
const query = parseBlogGridSearchParams(Astro.url.searchParams, { pageSize: 12 });

const pageData = await PageService.loadBlogIndexPageData({ api, lang, ...query });
const { blogs, categories, blogPageDetail, pagination } = pageData;

const blogSEO = blogPageDetail?.seo || {
  title: { zh: "博客与资讯 - Kellogg Fashion", en: "Blog & Resources - Kellogg Fashion" },
  description: {
    zh: "浏览 Kellogg Fashion 博客，获取最新行业资讯、面料指南、服装制造技巧和流行趋势报告。",
    en: "Explore Kellogg Fashion blog for industry news, fabric guides, OEM tips, and trend reports from a leading apparel manufacturer.",
  },
};
---

<Layout seo={blogSEO} lang={lang}>
  <BlogIndexView
    blogs={blogs}
    categories={categories}
    totalBlogs={pagination.total}
    initialPage={pagination.page}
    initialCategory={query.category}
    initialSort={query.sort}
    lang={lang}
  />
</Layout>
