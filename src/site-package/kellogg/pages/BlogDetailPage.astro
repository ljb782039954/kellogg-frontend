---
import Layout from "../layouts/SiteLayout.astro";
import OptimizedImage from "@core/components/OptimizedImage";
import { api } from "@services/api";
import { SiteService } from "@services/siteService";
import type { Blog, BlogSummary } from "../types";
import "../styles/blog-prose.css";
import { sanitizeCmsHtml } from "@core/lib/contentSecurity";

interface Props {
  blogSlug: string;
}

const { blogSlug } = Astro.props;
const siteData = await SiteService.getSiteData(Astro);
const { lang } = siteData;

let blog: Blog | null = null;
let relatedBlogs: BlogSummary[] = [];

try {
  blog = await api.getBlog(blogSlug || "");
} catch {
  return Astro.redirect("/blog");
}

if (!blog) return Astro.redirect("/blog");

try {
  const resp = await api.getBlogs({
    pageSize: 20,
    category: blog.category || undefined,
    sort: "newest",
  });
  relatedBlogs = (resp.data || [])
    .filter((item: BlogSummary) => item.slug !== blog!.slug)
    .slice(0, 4);
} catch {}

function t(zh: string, en: string) {
  return lang === "zh" ? zh : en;
}

const title = lang === "zh" ? blog.title_zh : blog.title_en;
const content = lang === "zh" ? blog.content_zh : blog.content_en;
const summary = lang === "zh" ? blog.summary_zh : blog.summary_en;
const seoTitle = (lang === "zh" ? blog.seo_title_zh : blog.seo_title_en) || title;
const seoDesc = (lang === "zh" ? blog.seo_desc_zh : blog.seo_desc_en) || summary || "";

function formatDate(date: string | null) {
  if (!date) return "";
  return new Date(date).toLocaleDateString(lang === "zh" ? "zh-CN" : "en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

function getBlogTitle(item: BlogSummary) {
  return lang === "zh" ? item.title_zh : item.title_en;
}

const words = content
  ? lang === "zh"
    ? content.replace(/\s/g, "").length / 300
    : content.split(/\s+/).length / 200
  : 0;
const readingTime = Math.max(1, Math.round(words));

let htmlContent = "";
try {
  const { marked } = await import("marked");
  htmlContent = sanitizeCmsHtml(await marked.parse(content || ""));
} catch {
  htmlContent = sanitizeCmsHtml((content || "")
    .replace(/^### (.+)$/gm, "<h3>$1</h3>")
    .replace(/^## (.+)$/gm, "<h2>$1</h2>")
    .replace(/^# (.+)$/gm, "<h1>$1</h1>")
    .replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>")
    .replace(/\*(.+?)\*/g, "<em>$1</em>")
    .replace(/\n\n/g, "</p><p>")
    .replace(/^/, "<p>")
    .replace(/$/, "</p>"));
}
---

<Layout title={seoTitle} description={seoDesc} lang={lang}>
  <nav class="max-w-7xl mx-auto px-6 py-4 text-sm text-gray-500 flex items-center gap-2">
    <a href="/" class="hover:text-gray-900 transition-colors">{t("首页", "Home")}</a>
    <span>/</span>
    <a href="/blog" class="hover:text-gray-900 transition-colors">{t("博客", "Blog")}</a>
    <span>/</span>
    <span class="text-gray-800 font-medium line-clamp-1 max-w-xs">{title}</span>
  </nav>

  {blog.cover_image && (
    <div class="max-w-7xl mx-auto px-6 mb-8">
      <div class="w-full h-64 md:h-96 rounded-2xl overflow-hidden">
        <OptimizedImage
          src={blog.cover_image}
          alt={title}
          width={1200}
          class="w-full h-full object-cover"
        />
      </div>
    </div>
  )}

  <div class="max-w-7xl mx-auto px-6 pb-20">
    <div class="flex gap-10 items-start">
      <article class="flex-1 min-w-0">
        <header class="mb-8">
          {blog.category && (
            <span class="inline-block px-3 py-1 bg-blue-50 text-blue-600 text-xs font-semibold rounded-full mb-4">
              {blog.category}
            </span>
          )}
          <h1 class="text-3xl md:text-4xl font-bold text-gray-900 leading-tight mb-4">
            {title}
          </h1>

          <div class="flex flex-wrap items-center gap-3 text-sm text-gray-500 pb-6 border-b border-gray-100">
            <div class="flex items-center gap-1.5">
              <div class="w-6 h-6 rounded-full bg-gray-200 flex items-center justify-center text-xs font-bold text-gray-600">
                {blog.author[0].toUpperCase()}
              </div>
              <span>{blog.author}</span>
            </div>
            <span>·</span>
            <span>{formatDate(blog.publish_date || blog.created_at)}</span>
            <span>·</span>
            <span>{t(`${readingTime} 分钟阅读`, `${readingTime} min read`)}</span>
            <span>·</span>
            <span class="flex items-center gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle>
              </svg>
              {blog.view_count.toLocaleString()}
              {t("次阅读", "views")}
            </span>
          </div>

          {blog.tags && blog.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-4">
              {blog.tags.map((tag) => (
                <span class="inline-flex items-center gap-1 px-2.5 py-1 bg-gray-100 text-gray-600 text-xs font-medium rounded-lg">
                  # {tag}
                </span>
              ))}
            </div>
          )}
        </header>

        <div class="blog-prose" set:html={htmlContent} />

        <div class="mt-12 pt-8 border-t border-gray-100">
          <p class="text-sm font-semibold text-gray-500 mb-3">
            {t("分享这篇文章", "Share this article")}
          </p>
          <div class="flex gap-2">
            <a
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(Astro.url.href)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="px-4 py-2 text-sm bg-black text-white rounded-xl hover:bg-gray-800 transition-colors font-medium"
            >
              X (Twitter)
            </a>
            <a
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.href)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="px-4 py-2 text-sm bg-blue-700 text-white rounded-xl hover:bg-blue-800 transition-colors font-medium"
            >
              LinkedIn
            </a>
            <button
              id="copy-link-btn"
              class="px-4 py-2 text-sm bg-gray-100 text-gray-700 rounded-xl hover:bg-gray-200 transition-colors font-medium"
            >
              {t("复制链接", "Copy Link")}
            </button>
          </div>
        </div>
      </article>

      <aside class="w-64 flex-shrink-0 sticky top-24 space-y-6 hidden lg:block">
        {relatedBlogs.length > 0 && (
          <div class="bg-white rounded-2xl border border-gray-100 p-5 shadow-sm">
            <h3 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-4">
              {t("相关文章", "Related Articles")}
            </h3>
            <div class="space-y-4">
              {relatedBlogs.slice(0, 3).map((item) => (
                <a href={`/blog/${item.slug}`} class="flex gap-3 group">
                  <div class="w-14 h-14 rounded-lg overflow-hidden bg-gray-100 flex-shrink-0">
                    {item.cover_image ? (
                      <OptimizedImage
                        src={item.cover_image}
                        alt={getBlogTitle(item)}
                        width={100}
                        class="w-full h-full object-cover"
                      />
                    ) : (
                      <div class="w-full h-full bg-gradient-to-br from-gray-100 to-gray-200" />
                    )}
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-semibold text-gray-800 group-hover:text-blue-600 transition-colors line-clamp-2 leading-snug">
                      {getBlogTitle(item)}
                    </p>
                    <p class="text-xs text-gray-400 mt-1">
                      {formatDate(item.publish_date || item.created_at)}
                    </p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

        <a
          href="/blog"
          class="flex items-center gap-2 px-4 py-3 bg-gray-900 text-white rounded-xl hover:bg-gray-700 transition-colors text-sm font-medium w-full justify-center"
        >
          ← {t("返回博客列表", "Back to Blog")}
        </a>
      </aside>
    </div>

    {relatedBlogs.length > 0 && (
      <section class="mt-16 pt-12 border-t border-gray-100">
        <h2 class="text-2xl font-bold text-gray-900 mb-8">
          {t("你可能也感兴趣", "You May Also Like")}
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {relatedBlogs.map((item) => (
            <a
              href={`/blog/${item.slug}`}
              class="group block bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
            >
              <div class="aspect-[16/9] bg-gray-100 overflow-hidden">
                {item.cover_image ? (
                  <OptimizedImage
                    src={item.cover_image}
                    alt={getBlogTitle(item)}
                    width={600}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  />
                ) : (
                  <div class="w-full h-full bg-gradient-to-br from-gray-50 to-gray-100" />
                )}
              </div>
              <div class="p-4">
                {item.category && (
                  <span class="text-[10px] font-semibold text-blue-500 uppercase tracking-wider">
                    {item.category}
                  </span>
                )}
                <h3 class="text-sm font-bold text-gray-800 mt-1 line-clamp-2 group-hover:text-blue-600 transition-colors leading-snug">
                  {getBlogTitle(item)}
                </h3>
                <p class="text-xs text-gray-400 mt-2">
                  {formatDate(item.publish_date || item.created_at)}
                </p>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</Layout>

<style>
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  const copyBtn = document.getElementById("copy-link-btn");
  copyBtn?.addEventListener("click", async () => {
    try {
      await navigator.clipboard.writeText(window.location.href);
      if (copyBtn) {
        const original = copyBtn.textContent || "";
        copyBtn.textContent = "✓ Copied!";
        setTimeout(() => {
          copyBtn.textContent = original;
        }, 2000);
      }
    } catch {
      const input = document.createElement("input");
      input.value = window.location.href;
      document.body.appendChild(input);
      input.select();
      document.execCommand("copy");
      document.body.removeChild(input);
    }
  });
</script>
