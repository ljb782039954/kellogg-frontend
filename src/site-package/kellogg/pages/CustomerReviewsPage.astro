---
import Layout from "../layouts/SiteLayout.astro";
import CustomerReviews from "./customerReviews/CustomerReviews";
import { toCustomerReviewsViewProps } from "@/core-webApp/components/customerReviewsAdapter";
import { api } from "@services/api";
import { kelloggSiteConfig } from "../config";
import { SiteService } from "@services/siteService";

const siteData = await SiteService.getSiteData(Astro);
const { lang } = siteData;

let customerReviewsPage: any = null;
let reviews: any[] = [];
try {
  [customerReviewsPage, reviews] = await Promise.all([
    api.getPageById("customer-reviews"),
    api.getReviews(),
  ]);
} catch (error) {
  console.error("[Customer Reviews SSR] Failed to fetch customer-reviews page details:", error);
}

const pageSEO = customerReviewsPage?.seo || {
  title: { zh: "客户评价 - Kellogg Fashion", en: "Customer Reviews - Kellogg Fashion" },
  description: {
    zh: "来自全球品牌买家的真实穿搭视频与成衣评价，见证 Kellogg Fashion 的服装制造品质。",
    en: "Real try-on videos and honest client reviews from global brand buyers — see Kellogg Fashion apparel quality in action.",
  },
};
const customerReviewsProps = toCustomerReviewsViewProps(kelloggSiteConfig ,reviews, lang);
---

<Layout seo={pageSEO} lang={lang}>
  <section class="relative bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 text-white overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 -left-4 w-72 h-72 bg-yellow-500 rounded-full mix-blend-multiply filter blur-2xl"></div>
      <div class="absolute -bottom-8 right-0 w-72 h-72 bg-amber-500 rounded-full mix-blend-multiply filter blur-2xl"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-6 py-20 text-center">
      <span class="inline-block px-3 py-1 bg-white/10 text-white/80 text-xs font-semibold rounded-full uppercase tracking-widest mb-4">
        {lang === "zh" ? "客户见证" : "Testimonials"}
      </span>
      <h1 class="text-4xl md:text-5xl font-bold mb-4 tracking-tight">
        {lang === "zh" ? "客户评价" : "Customer Reviews"}
      </h1>
      <p class="text-lg text-white/70 max-w-xl mx-auto">
        {lang === "zh" ? "听听来自全球合作伙伴的真实反馈，见证高品质服装制造。" : "Real feedback from global partners, witnessing premium apparel manufacturing."}
      </p>
    </div>
  </section>

  <CustomerReviews {...customerReviewsProps} />
</Layout>
