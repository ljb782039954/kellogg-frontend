---
import type { Product, Language } from "../../types";
import { formatPrice } from "../../lib/currency";
import OptimizedImage from "../ui/OptimizedImage.astro";
import { createTranslate } from "../../lib/i18n";

interface Props {
  product: Product;
  index?: number;
  lang: Language;
}

const { product, index = 0, lang } = Astro.props;
const t = createTranslate(lang);
const bulkPrice = product.bulkPrices?.[0];
---

<div class="bg-white rounded-xl border border-gray-100 overflow-hidden hover:shadow-lg transition-all hover:-translate-y-1 group h-full flex flex-col">
  <div class="aspect-[3/4] overflow-hidden relative bg-gray-50">
    {product.image ? (
      <OptimizedImage
        src={product.image}
        alt={t(product.name)}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
        responsive={{
          sm: 320,
          md: 400,
          lg: 400
        }}
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-gray-300">
        No Image
      </div>
    )}
    {product.tag && (
      <span class="absolute top-3 left-3 px-3 py-1 bg-red-500 text-white text-[10px] md:text-xs font-semibold rounded-full shadow-sm z-10">
        {t(product.tag)}
      </span>
    )}
  </div>

  <div class="p-3 md:p-4 flex flex-col flex-grow">
    <h3 class="font-medium text-gray-800 mb-2 line-clamp-2 min-h-[2.5rem] md:min-h-[3rem] group-hover:text-primary transition-colors text-sm md:text-base">
      {t(product.name)}
    </h3>
    <div class="flex items-center justify-between mt-auto">
      {bulkPrice && (
        <>
          <p class="text-[10px] md:text-xs font-semibold text-gray-400 uppercase group-hover:text-amber-600 transition-colors">
            {bulkPrice.maxQty
              ? `${bulkPrice.minQty}-${bulkPrice.maxQty} PCS`
              : `${bulkPrice.minQty}+ PCS`}
          </p>
          <p class="text-sm md:text-base font-bold text-gray-900">
            {formatPrice(bulkPrice.price)}
          </p>
        </>
      )}
    </div>
  </div>
</div>
