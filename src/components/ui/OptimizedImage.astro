---
import { api } from "../../lib/api";
import { cn } from "../../lib/utils";

interface Props extends astroHTML.JSX.ImgHTMLAttributes {
  src: string | null | undefined;
  width?: number;
  height?: number;
  priority?: boolean;
  responsive?: {
    sm?: number;
    md?: number;
    lg?: number;
    xl?: number;
  };
  class?: string;
}

const {
  src,
  width = 768,
  height,
  priority = false,
  responsive,
  class: className,
  alt = "",
  sizes: propSizes,
  ...props
} = Astro.props;

// 1. 计算主 src
const imageUrl = src ? api.getOptimizedImageUrl(src, width) : "";

// 2. 计算 srcSet
let srcSet = undefined;
if (src) {
  if (responsive) {
    const widths = [
      responsive.sm,
      responsive.md,
      responsive.lg,
      responsive.xl,
    ].filter((w): w is number => !!w);

    if (widths.length > 0) {
      srcSet = widths
        .sort((a, b) => a - b)
        .map((w) => `${api.getOptimizedImageUrl(src, w)} ${w}w`)
        .join(", ");
    }
  }

  if (!srcSet) {
    const defaultWidths = [320, 480, 768, 1024, 1200, 1600];
    srcSet = defaultWidths
      .map((w) => `${api.getOptimizedImageUrl(src, w)} ${w}w`)
      .join(", ");
  }
}

// 3. 计算 sizes
let sizes = propSizes;
if (!sizes) {
  if (!responsive) {
    sizes = "(max-width: 768px) 100vw, 1200px";
  } else {
    const parts = [];
    if (responsive.xl) parts.push(`(min-width: 1280px) ${responsive.xl}px`);
    if (responsive.lg) parts.push(`(min-width: 1024px) ${responsive.lg}px`);
    if (responsive.md) parts.push(`(min-width: 768px) ${responsive.md}px`);
    if (responsive.sm) parts.push(`(min-width: 640px) ${responsive.sm}px`);
    parts.push(`${width}px`);
    sizes = parts.join(", ");
  }
}
---

{
  !src ? (
    <div
      class={cn("bg-gray-100 animate-pulse rounded-lg", className)}
      style={{ width: width ? `${width}px` : "100%", height: height ? `${height}px` : "100%" }}
    />
  ) : (
    <img
      src={imageUrl}
      srcset={srcSet}
      sizes={sizes}
      width={width}
      height={height}
      alt={alt}
      loading={priority ? "eager" : "lazy"}
      decoding="async"
      class={cn("transition-opacity duration-300", className)}
      style="opacity: 0;"
      onload="this.style.opacity = '1'"
      {...props}
    />
  )
}
