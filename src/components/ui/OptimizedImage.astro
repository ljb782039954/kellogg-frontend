---
import { api } from "../../lib/api";
import { cn } from "../../lib/utils";

interface Props extends astroHTML.JSX.ImgHTMLAttributes {
  src: string | null | undefined;
  width?: number;
  height?: number;
  priority?: boolean;
  class?: string;
}

const {
  src,
  width = 800,
  height,
  priority = false,
  class: className,
  alt = "",
  sizes: propSizes,
  ...props
} = Astro.props;

// 1. 计算主 src
const imageUrl = src ? api.getOptimizedImageUrl(src, width) : "";

// 2. 计算 srcSet
let srcSet = undefined;
if (src) {
  const defaultWidths = [200, 320, 480, 640, 800, 960, 1080, 1280, 1440, 1600, 1920];
  srcSet = defaultWidths
    .map((w) => `${api.getOptimizedImageUrl(src, w)} ${w}w`)
    .join(", ");
}

// 3. 计算 sizes
const sizes = propSizes || "(max-width: 768px) 100vw, 33vw";
---

{
  !src ? (
    <div
      class={cn("bg-gray-100 animate-pulse rounded-lg", className)}
      style={{ width: width ? `${width}px` : "100%", height: height ? `${height}px` : "100%" }}
    />
  ) : (
    <img
      src={imageUrl}
      srcset={srcSet}
      sizes={sizes}
      width={width}
      height={height}
      alt={alt}
      loading={priority ? "eager" : "lazy"}
      decoding="async"
      class={cn("transition-opacity duration-300", className)}
      {...props}
    />
  )
}
