---
import { api } from "../../lib/api";
import type { Translation, Language } from "../../types";
import { createTranslate } from "../../lib/i18n";
import { Sparkles } from "lucide-react";

interface Props {
  tag?: Translation;
  title?: Translation;
  subtitle?: Translation;
  image?: string;
  lang: Language;
}

const { tag, title, subtitle, image, lang } = Astro.props;
const t = createTranslate(lang);
const optimizedBgImage = image ? api.getOptimizedImageUrl(image, 1920) : '';
---

<section class="relative h-[40vh] flex items-center justify-center overflow-hidden bg-gray-900">
  <div
    class="absolute inset-0 bg-cover bg-center opacity-40"
    style={`background-image: url('${optimizedBgImage}')`}
  ></div>
  <div class="relative z-10 text-center px-4">
    <div class="flex items-center justify-center gap-2 mb-4">
      <Sparkles className="w-5 h-5 text-amber-400" />
      <span class="text-amber-400 font-medium tracking-widest text-sm uppercase">
        {tag ? t(tag) : ''}
      </span>
    </div>
    <h1 class="text-5xl md:text-7xl font-bold text-white mb-6 tracking-tight">
      {title ? t(title) : ''}
    </h1>
    <p class="text-lg md:text-xl text-white max-w-2xl mx-auto font-light">
      {subtitle ? t(subtitle) : ''}
    </p>
  </div>
</section>
