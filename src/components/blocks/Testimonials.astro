---
import { Star, } from "lucide-react";
import type { Translation, Language } from "../../types";
import SectionHeader from "../SectionHeader.astro";
import OptimizedImage from "../ui/OptimizedImage.astro";
import { createTranslate } from "../../lib/i18n";

interface Testimonial {
  id: number;
  name: Translation;
  role?: Translation;
  content: Translation;
  avatar?: string;
}

interface Props {
  title?: Translation;
  subtitle?: Translation;
  items?: Testimonial[];
  lang: Language;
}

const { title, subtitle, items = [], lang } = Astro.props;
const t = createTranslate(lang);
---

{
  items.length > 0 && (
    <section class="py-12 w-full">
      <div class="container mx-auto px-4">
        {title && (
          <SectionHeader
            lang={lang}
            title={title}
            subtitle={subtitle}
            theme="light"
          />
        )}

        <div class="grid grid-cols-[repeat(auto-fit,minmax(300px,1fr))] gap-4">
          {items.map((item) => (
            <div class="bg-gray-50 rounded-lg p-4 hover:shadow-md transition-shadow">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-10 h-10 bg-gray-200 rounded-full overflow-hidden">
                  {item.avatar && (
                    <OptimizedImage
                      src={item.avatar}
                      alt=""
                      width={80}
                      class="w-full h-full object-cover"
                    />
                  )}
                </div>
                <div>
                  <div class="font-medium text-sm">{t(item.name)}</div>
                  {item.role && (
                    <div class="text-xs text-gray-500">{t(item.role)}</div>
                  )}
                </div>
              </div>
              <p class="text-sm text-gray-600 line-clamp-3">
                {t(item.content)}
              </p>
              
              <div class="flex mt-3">
                {[1, 2, 3, 4, 5].map((star) => (
                  <Star
                    key={star}
                    size={16}
                    className="fill-yellow-400 text-yellow-400"
                  />
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}
