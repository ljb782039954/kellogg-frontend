---
/**
 * CustomerReviews.astro — Customer Reviews block component
 * Fetches published customer reviews from the API and renders them
 * as a single-column left-media / right-text card list.
 */
import type { Language } from "../../types";
import OptimizedImage from "../ui/OptimizedImage.astro";
import { api } from "../../lib/api";
import { createTranslate } from "../../lib/i18n";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = createTranslate(lang);

// Fetch all published reviews
let reviews: any[] = [];
try {
  reviews = await api.getReviews();
} catch (e) {
  console.error('[CustomerReviews] Failed to fetch reviews:', e);
}

/**
 * Extract YouTube video ID from various URL formats.
 */
function extractYoutubeId(url: string): string | null {
  if (!url) return null;
  const patterns = [
    /[?&]v=([a-zA-Z0-9_-]{11})/,
    /youtu\.be\/([a-zA-Z0-9_-]{11})/,
    /youtube\.com\/embed\/([a-zA-Z0-9_-]{11})/,
    /youtube\.com\/shorts\/([a-zA-Z0-9_-]{11})/,
  ];
  for (const pat of patterns) {
    const m = url.match(pat);
    if (m) return m[1];
  }
  return null;
}
---

{reviews.length === 0 ? (
  <section class="max-w-5xl mx-auto px-6 py-24 text-center text-gray-400">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-14 h-14 mx-auto mb-4 stroke-[1.2]" viewBox="0 0 24 24" fill="none" stroke="currentColor">
      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
    </svg>
    <p class="text-lg font-medium">{lang === 'zh' ? '暂无评价内容' : 'No customer reviews yet'}</p>
    <p class="text-sm mt-1">{lang === 'zh' ? '敬请期待客户真实反馈' : 'Customer reviews coming soon'}</p>
  </section>
) : (
  <section class="max-w-5xl mx-auto px-6 py-12 space-y-14">
    {reviews.map((review) => {
      const youtubeId = review.media_type === 'video' ? extractYoutubeId(review.media_url) : null;
      const embedUrl = youtubeId ? `https://www.youtube.com/embed/${youtubeId}?rel=0` : null;
      const reviewText = lang === 'zh' ? review.review_text_zh : review.review_text_en;

      // Star calculation
      const fullStars = Math.floor(review.rating);
      const hasHalf = (review.rating - fullStars) >= 0.5;
      const emptyStars = 5 - fullStars - (hasHalf ? 1 : 0);

      return (
        <article class="cs-card group relative overflow-hidden">
          <div class="flex flex-col md:flex-row">
            <!-- LEFT: Media -->
            <div class="w-full md:w-[48%] flex-shrink-0 p-5 md:p-6">
              {embedUrl ? (
                <div class="w-full aspect-video rounded-2xl overflow-hidden shadow-md bg-black">
                  <iframe
                    class="w-full h-full"
                    src={embedUrl}
                    title={`Review by ${review.client_name}`}
                    frameborder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    allowfullscreen
                    loading="lazy"
                  ></iframe>
                </div>
              ) : review.media_url ? (
                <div class="w-full aspect-video rounded-2xl overflow-hidden shadow-md">
                  <OptimizedImage
                    src={review.media_url}
                    alt={`${review.client_name} review`}
                    width={800}
                    class="w-full h-full object-cover"
                  />
                </div>
              ) : (
                <div class="w-full aspect-video rounded-2xl bg-gray-100 flex items-center justify-center">
                  <svg class="w-12 h-12 text-gray-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <rect x="2" y="3" width="20" height="14" rx="2"/>
                    <path d="M8 21h8M12 17v4"/>
                  </svg>
                </div>
              )}
            </div>

            <!-- RIGHT: Text -->
            <div class="w-full md:w-[52%] flex flex-col justify-center px-5 pb-7 pt-2 md:pt-7 md:pr-8 md:pl-2">
              <!-- Name & country -->
              <h3 class="font-serif text-2xl md:text-3xl font-semibold text-gray-900 tracking-tight leading-snug">
                {review.client_name}
              </h3>
              {review.country && (
                <p class="text-sm text-gray-400 mt-1 flex items-center gap-1.5">
                  <svg class="w-3.5 h-3.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                  </svg>
                  {review.country}
                </p>
              )}

              <!-- Stars -->
              <div class="flex items-center gap-1 mt-3">
                {Array.from({ length: fullStars }).map(() => (
                  <svg class="w-5 h-5 fill-yellow-400 text-yellow-400" viewBox="0 0 24 24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                ))}
                {hasHalf && (
                  <span class="relative w-5 h-5 inline-block">
                    <svg class="w-5 h-5 fill-gray-200 text-gray-200 absolute" viewBox="0 0 24 24">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                    <span class="absolute inset-0 overflow-hidden" style="width: 50%">
                      <svg class="w-5 h-5 fill-yellow-400 text-yellow-400" viewBox="0 0 24 24">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                      </svg>
                    </span>
                  </span>
                )}
                {Array.from({ length: emptyStars }).map(() => (
                  <svg class="w-5 h-5 fill-gray-200 text-gray-200" viewBox="0 0 24 24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                ))}
                <span class="text-sm text-gray-400 ml-1">{review.rating.toFixed(1)}</span>
              </div>

              <!-- Review body (HTML rendered for bold/italic) -->
              <div class="cs-text mt-4 text-gray-600 leading-relaxed text-[15px]" set:html={reviewText} />
            </div>
          </div>
        </article>
      );
    })}
  </section>
)}

<style>
  /* Serif font for client names */
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&display=swap');
  .font-serif { font-family: 'Playfair Display', Georgia, serif; }

  /* Formatted review text */
  .cs-text strong { font-weight: 700; color: #1a1a1a; }
  .cs-text em    { font-style: italic; color: #4b5563; }

  /* Entrance animation */
  .cs-card {
    opacity: 0;
    transform: translateY(24px);
    animation: csCardIn 0.5s ease forwards;
  }
  @keyframes csCardIn { to { opacity: 1; transform: translateY(0); } }
  .cs-card:nth-child(1) { animation-delay: 0.05s; }
  .cs-card:nth-child(2) { animation-delay: 0.12s; }
  .cs-card:nth-child(3) { animation-delay: 0.19s; }
  .cs-card:nth-child(4) { animation-delay: 0.26s; }
  .cs-card:nth-child(n+5) { animation-delay: 0.33s; }
</style>
