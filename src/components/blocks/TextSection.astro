---
import type { Translation, Language } from "../../types";
import { createTranslate } from "../../lib/i18n";

interface Props {
  title?: Translation;
  content?: Translation;
  alignment?: 'left' | 'center' | 'right';
  paddingY?: 'small' | 'medium' | 'large';
  backgroundColor?: string;
  lang: Language;
}

const { title, content, alignment = 'center', backgroundColor, lang } = Astro.props;
const t = createTranslate(lang);

const alignClasses = {
  left: 'text-left',
  center: 'text-center',
  right: 'text-right'
};

const paddingClasses = {
  small: 'py-8',
  medium: 'py-16',
  large: 'py-24'
};
---

<section 
  class:list={[
    "relative", 
    alignClasses[alignment], 
    paddingClasses[Astro.props.paddingY || 'medium']
  ]}
  style={backgroundColor ? `background-color: ${backgroundColor}` : undefined}
>
  <div class="container mx-auto px-4">
    {title && (
      <h2 class="text-3xl md:text-5xl font-bold text-gray-900 mb-6">
        {t(title)}
      </h2>
    )}
    {content && (
      <p class:list={[
        "text-gray-600 max-w-3xl text-lg md:text-xl leading-relaxed",
        alignment === 'center' ? 'mx-auto' : ''
      ]}>
        {t(content)}
      </p>
    )}
  </div>
</section>
